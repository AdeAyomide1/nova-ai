# ─── NOVA AI — Environment Variables ───────────────────────────────────────
# Copy this file, rename it to .env, and fill in your keys.

# REQUIRED: Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OPTIONAL: Get free key from https://brave.com/search/api/
# Enables real web research. Without it, NOVA answers from training data only.
BRAVE_API_KEY=your_brave_search_api_key_here

# Server port (leave as 3001 unless you have a conflict)
PORT=3001
